{
  "manifest_version": 3,
  "name": "cust*m Tab",
  "short_name": "cust*m Tab",
  "version": "1.0.0",
  "description": "Your tab. Your rules. Zero-friction custom new tab. Setup in 30 seconds.",
  "minimum_chrome_version": "114",
  "permissions": ["tabs", "storage", "alarms", "notifications"],
  "optional_host_permissions": ["<all_urls>"],
  "chrome_url_overrides": { "newtab": "newtab.html" },
  "options_ui": { "page": "options.html", "open_in_tab": true },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Open cust*m Tab Settings",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["newtab.html", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
